# for peer review
# cp .env.example .env

# GCP Configuration
GCP_PROJECT_ID=your-gcp-project-id
GCS_BUCKET_NAME=solana-validator-data-lake-your-gcp-project-id
BQ_DATASET_STAGING=solana_validator_economics_staging
BQ_DATASET_WAREHOUSE=solana_validator_economics
BQ_LOCATION=US

# GCP credentials (mounted into Docker)
GOOGLE_APPLICATION_CREDENTIALS=/opt/airflow/config/gcp-key.json

# Airflow settings
AIRFLOW__CORE__LOAD_EXAMPLES=false
AIRFLOW__CORE__EXECUTOR=LocalExecutor

# Pipeline settings
EXTRACT_DAYS=90
SOLANA_PUBLIC_DATASET=bigquery-public-data.crypto_solana_mainnet_us